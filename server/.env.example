# OpenAI (for screenshot analysis + coach narrative)
OPENAI_API_KEY=
# Optional: OPENAI_MODEL=gpt-4o-mini (default), OPENAI_VISION_MODEL for screenshots only

# Strava (create app at https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Callback URL registered in Strava app (backend receives the code here)
STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback
# Where to send the user after OAuth (your frontend)
FRONTEND_ORIGIN=http://localhost:5173
