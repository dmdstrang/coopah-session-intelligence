{
  "name": "coopah-session-intelligence",
  "private": true,
  "scripts": {
    "predev": "sh -c 'p=$(lsof -ti :3001); [ -n \"$p\" ] && kill -9 $p; true'",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix server && npm run build --prefix client",
    "start": "node server/dist/index.js",
    "db:generate": "npm run db:generate --prefix server",
    "db:migrate": "npm run db:migrate --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
